{
  "name": "agentic-harnesses-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive visualizer for agentic coding harness loops",
  "scripts": {
    "validate": "node scripts/validate-loops.mjs",
    "vendor:artificer": "node ../scripts/vendor-artificer.mjs",
    "predev": "npm run vendor:artificer",
    "dev": "vite",
    "prebuild": "npm run vendor:artificer",
    "build": "npm run validate && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cameronsjo/artificer": "0.18.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.17.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
