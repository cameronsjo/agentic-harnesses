# Cloned harness sources — analyzed in place, never committed (see docs/methodology.md)
sources/

# Web visualizer build artifacts
site/node_modules/
site/dist/
site/.vite/

# Artificer runtime files — GENERATED from the pinned @cameronsjo/artificer
# package by scripts/vendor-artificer.mjs (predev/prebuild). The lockfile is the
# single version source of truth; only assets/ (fonts, favicon, og) stays committed
# (version-stable url() paths). The `*` globs don't reach into assets/.
site/public/artificer/*.css
site/public/artificer/*.js
site/public/artificer/*.json

# Node / tooling
node_modules/
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
.claude/intros/
.claude/worktrees/
.claude/scheduled_tasks.lock

# External tooling output (CodeBoarding)
.codeboarding/

# review-loop state (local, ephemeral)
.review-loop.local.md

# retro raw-material index (local)
.claude/retro/
